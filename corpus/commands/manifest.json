    "clipboard": "agent_notes/foo/",
    "replacements": [
      {
        "heard": "slash resume",
        "replace": "/resume"
      },
      {
        "heard": "slash (\\w+)",
        "replace": "/$1",
        "isRegex": true
      },
      {
        "heard": "/resume",
        "replace": "/resume"
      },
      {
        "heard": "/dog",
        "replace": "/dog"
      }
    ]
  },
