.DS_Store
.build/
*.app
agent_notes/
.claude/
.codex/
.pi/
.agents/
AGENTS.override.md
CLAUDE.local.md

# Throwaway M0 de-risk spikes — not production (spikes/README.md)
spikes/

# Downloaded STT weights — runtime-downloaded, never committed (design.md §4.1, §5)
models/

# Speech corpus — personal voice recordings + run output stay local. The kit (each sub-corpus's
# manifest, the record.sh/compare.sh harnesses, READMEs, and the voices/ generator + analysis
# scripts) IS committed so every corpus is reproducible against your own voice.
# stt/ engine-accuracy (WER benchmark) corpus: recorded clips + run output stay local
corpus/stt/*.wav
# BenchmarkRunner writes results.json (and results-fuzzy.json for the --fuzzy arm) into whatever
# sub-corpus dir it is pointed at (stt, commands, a silence sweep) — never committed regardless
corpus/*/results.json
corpus/*/results-fuzzy.json
# voices/ "scratch that" study: generated + recorded clips + local TTS venv stay local (manifest.json
# IS committed — it holds the hand-recorded human takes + prosody notes, and is the record.sh --voices source)
corpus/voices/*.wav
corpus/voices/.ttsenv
corpus/voices/.tmpwav
# commands/ verbal-command verification corpus: recorded/TTS clips stay local; manifest.json IS committed
corpus/commands/*.wav
# distractors/ recognition-bias false-fire corpus: generated TTS clips stay local; manifest.json +
# gen.py + README.md IS committed (reproducible via gen.py)
corpus/distractors/*.wav
corpus/distractors/.tmpwav
# bias/ recognition-bias corpus (ContextASR-Bench derived): extracted TTS clips + the fetched shard/
# metadata stay local; manifest.json + build.py + fetch.sh IS committed (reproducible via fetch.sh)
corpus/bias/*.wav
corpus/bias/shard.tar
corpus/bias/ContextASR-Speech_English.jsonl

# rewrite-prompt eval (`KeyScribe --rewrite-eval`): cases.json + README ARE committed; per-run
# attempt dumps (model outputs, connection/model identity) stay local
evals/rewrite/results/

# direnv: local env (real .envrc may hold the notary API key); commit .envrc.example instead
.envrc


# release DMG build artifact (uploaded to GitHub Releases, never committed)
KeyScribe-*.dmg

# release preflight stamp (written by scripts/preflight.sh, keyed to a commit)
.preflight-pass
corpus/commands/baseline.json
.preflight-run/
.preflight-state/

# UI test harness: project.yml + *.swift are committed; the xcodeproj is generated by xcodegen
UITests/*.xcodeproj/
UITests/DerivedData/
UITests/map/
